{
  "name": "rote-toolkit",
  "version": "0.3.4",
  "description": "CLI and MCP toolkit for Rote OpenKey API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rote-toolkit": "dist/cli.js",
    "rote": "dist/cli.js",
    "rote-mcp": "dist/mcp-standalone.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp-standalone.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "keywords": [
    "rote",
    "cli",
    "mcp",
    "openkey"
  ],
  "homepage": "https://github.com/Rabithua/rote-toolkit#readme",
  "bugs": {
    "url": "https://github.com/Rabithua/rote-toolkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rabithua/rote-toolkit.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "commander": "^14.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
